# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Shared password gate in front of the whole app (UI + API). Set to require a
# password before anyone can reach the app; leave blank to disable the gate.
# The GitHub webhook is exempt (it authenticates via signature).
APP_PASSWORD=""

# Better Auth
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET=""

# Better Auth GitHub OAuth
BETTER_AUTH_GITHUB_CLIENT_ID=""
BETTER_AUTH_GITHUB_CLIENT_SECRET=""

# Drizzle
DATABASE_URL="postgresql://postgres:password@localhost:5432/bandolier"

# GitHub webhook ingestion
GITHUB_WEBHOOK_SECRET=""      # set in your GitHub repo → Settings → Webhooks
GITHUB_TRIGGER_LABEL=""       # optional: only act on issues with this label (e.g. "claude-agent")

# GitHub App (bot identity for comments and other UX tie-ins). The App acts as
# itself (bandolier[bot]) on each repo it's installed on; user attribution for
# clone/push/PR still comes from the OAuth login above. Issue comments are only
# ever posted as the App — when it's not installed on a repo, the comment is
# skipped. All three required together to enable bot actions.
GITHUB_APP_ID=""              # numeric App id from the App's settings page
GITHUB_APP_PRIVATE_KEY=""     # PEM key; multi-line, store with \n escapes
GITHUB_APP_CLIENT_ID=""       # App OAuth client id (optional until login moves to the App)
GITHUB_APP_CLIENT_SECRET=""
NEXT_PUBLIC_GITHUB_APP_SLUG=""  # the App's public slug, used to link to its install page

# NOTE: There are no server-side GitHub or LLM provider credentials for agent
# work. Each user supplies their own (GitHub via OAuth login; AWS/Anthropic in
# account settings). The GitHub App above is the one server-held credential, and
# it is used only for bot-voice actions, never for attribution-sensitive work.
# Available models are queried live from each user's provider.