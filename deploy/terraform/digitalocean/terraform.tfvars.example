# Copy to terraform.tfvars and fill in. Credentials can instead come from env:
#   export DIGITALOCEAN_TOKEN=dop_v1_...
#   export SPACES_ACCESS_KEY_ID=DO...          # admin Spaces key, for bucket creation
#   export SPACES_SECRET_ACCESS_KEY=...

# ── Required (unless agent_only = true) ───────────────────────────────────────

# GitHub OAuth app (Settings → Developer settings → OAuth Apps). Callback URL:
#   <app url>/api/auth/callback/github
github_client_id     = ""
github_client_secret = ""

# ── Cluster mode ──────────────────────────────────────────────────────────────

# agent_only = false   # true → cluster only runs agent Jobs: no database, no
#                      # app Helm release; paste this cluster's kubeconfig into
#                      # a Bandolier app hosted elsewhere

# ── Placement & sizing ────────────────────────────────────────────────────────

# name   = "bandolier"
# region = "nyc3"          # must support DOKS + Spaces

# node_size = "s-4vcpu-8gb"
# min_nodes = 1
# max_nodes = 3  # default fits a fresh account's droplet limit of 3

# ── Database ──────────────────────────────────────────────────────────────────

# managed_database = true          # false → chart-bundled Postgres (evaluation only)
# database_size    = "db-s-1vcpu-1gb"

# ── DNS & TLS (optional; leave unset to use kubectl port-forward) ─────────────

# dns_zone          = "example.com"   # domain on DigitalOcean DNS
# create_dns_zone   = false           # true to add the zone to your account
# dns_record        = "bandolier"     # app at bandolier.example.com
# letsencrypt_email = "you@example.com"

# ── App ───────────────────────────────────────────────────────────────────────

# app_image_tag = "latest"  # pin a release (e.g. "v0.1.0") in production
# app_password  = ""        # optional shared password gate

# Optional GitHub App (webhook-triggered runs, bot comments):
# github_app_id            = ""
# github_app_private_key   = <<-EOT
#   -----BEGIN RSA PRIVATE KEY-----
#   ...
#   -----END RSA PRIVATE KEY-----
# EOT
# github_app_client_id     = ""
# github_app_client_secret = ""
# github_webhook_secret    = ""
# github_app_slug          = ""
